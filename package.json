{
  "name": "cloak-squads",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "test:unit": "vitest run -c tests/unit/vitest.config.ts",
    "test:int": "node --experimental-strip-types tests/integration/gatekeeper-instructions.test.ts && node --experimental-strip-types tests/integration/f1-send.test.ts && node --experimental-strip-types tests/integration/f2-batch.test.ts && node --experimental-strip-types tests/integration/f3-audit.test.ts && node --experimental-strip-types tests/integration/e2e-full-flow.test.ts",
    "test:devnet": "RUN_DEVNET_TESTS=1 node --experimental-strip-types tests/devnet/cloak-deposit.devnet.test.ts",
    "test:all": "pnpm test:unit && pnpm test:int",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "typecheck:packages": "tsc --noEmit",
    "typecheck:all": "pnpm -r exec tsc --noEmit",
    "prebuild:web": "pnpm -F @cloak-squads/core exec tsc --noEmit && pnpm -F web exec tsc --noEmit",
    "build:web": "pnpm prebuild:web && pnpm -F web build",
    "anchor:build": "NO_DNA=1 anchor build",
    "spike:devnet": "tsx scripts/spike-squads-devnet.ts",
    "spike:cloak": "tsx scripts/spike-cloak-devnet.ts",
    "probe:cloak": "tsx scripts/probe-cloak-devnet-pdas.ts",
    "probe:deposit": "tsx scripts/probe-cloak-deposit-manual.ts",
    "demo:setup": "tsx scripts/setup-demo-cofre.ts",
    "probe:real-deposit": "tsx scripts/probe-cloak-real-deposit.ts",
    "seed:demo": "tsx scripts/seed-test-data.ts",
    "seed:reset": "tsx scripts/seed-test-data.ts --reset",
    "audit:export": "tsx scripts/compliance-export.ts",
    "test:f1": "tsx scripts/test-f1-private-send.ts",
    "test:f4": "tsx scripts/test-f4-stealth-invoice.ts",
    "deploy:gk": "tsx scripts/deploy-gatekeeper.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@coral-xyz/anchor": "^0.31.1",
    "@solana/web3.js": "^1.98.4",
    "anchor-bankrun": "^0.5.0",
    "bs58": "^6.0.0",
    "solana-bankrun": "^0.4.0",
    "tsx": "^4.19.2",
    "turbo": "^2.3.0",
    "tweetnacl": "^1.0.3",
    "typescript": "^5.6.3",
    "vitest": "^1.6.1"
  },
  "dependencies": {
    "@cloak.dev/sdk-devnet": "0.1.5-devnet.1",
    "@sqds/multisig": "^2.1.4"
  }
}
