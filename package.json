{
  "name": "cloak-squads",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "test:int": "node --experimental-strip-types tests/integration/spike-cpi.test.ts && node --experimental-strip-types tests/integration/gatekeeper-instructions.test.ts",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "typecheck:packages": "tsc --noEmit",
    "anchor:build": "NO_DNA=1 anchor build",
    "spike:devnet": "tsx scripts/spike-squads-devnet.ts",
    "spike:cloak": "tsx scripts/spike-cloak-devnet.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@coral-xyz/anchor": "^0.31.1",
    "@solana/web3.js": "^1.98.4",
    "anchor-bankrun": "^0.5.0",
    "bs58": "^6.0.0",
    "solana-bankrun": "^0.4.0",
    "tsx": "^4.19.2",
    "turbo": "^2.3.0",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@cloak.dev/sdk": "^0.1.5",
    "@sqds/multisig": "^2.1.4"
  }
}
