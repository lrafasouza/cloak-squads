# ════════════════════════════════════════════════════════════════════════════
#  apps/web/.env.prod-like.example
#
#  Template for the env file `scripts/smoke-boot-prod.sh` loads to reproduce
#  a Render-like boot locally. Copy and fill before running the smoke:
#
#    cp apps/web/.env.prod-like.example apps/web/.env.prod-like
#    # then fill the values
#    scripts/smoke-boot-prod.sh
#
#  The actual file `apps/web/.env.prod-like` is gitignored via the `.env.*`
#  rule in the root .gitignore. Never commit real values.
#
#  Goal: every variable that `apps/web/lib/env.ts:serverEnvSchema` flags
#  as required in production must be present here. Missing any one of
#  these makes the smoke fail — which is the same way the real Render
#  deploy would fail, and exactly the signal we want before merging.
# ════════════════════════════════════════════════════════════════════════════

# ── Solana ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SOLANA_CLUSTER=devnet
NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com
# Optional, but recommended to test the WS path:
# NEXT_PUBLIC_RPC_WS_URL=wss://api.devnet.solana.com

NEXT_PUBLIC_CLOAK_PROGRAM_ID=Zc1kHfp4rajSMeASFDwFFgkHRjv7dFQuLheJoQus27h
NEXT_PUBLIC_CLOAK_RELAY_URL=https://api.devnet.cloak.ag
NEXT_PUBLIC_GATEKEEPER_PROGRAM_ID=AgFx8yS8bQnXSCSGfN3f8oz3HJGeF5rwLoWtfHTEEaAq
NEXT_PUBLIC_SQUADS_PROGRAM_ID=SQDS4ep65T869zMMBKyuUq6aD6EgTu8psMjkvj52pCf

# ── Database ──────────────────────────────────────────────────────────────
# Point at the same Postgres that prod uses (or a local clone). The smoke
# does NOT run migrations — bring the schema up first via `prisma migrate`.
DATABASE_URL=postgresql://aegis:aegis@localhost:5432/aegis_smoke

# ── Crypto keys ───────────────────────────────────────────────────────────
# Generate fresh test values BEFORE copying this template:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Then replace each <fill> below with the generated value. Do NOT commit
# real values back here — apps/web/.env.prod-like is gitignored.
SESSION_HMAC_KEY=<fill-with-32-byte-hex>
FIELD_CRYPTO_KEY=<fill-with-32-byte-hex>
# Optional dual-read fallback. Leave unset under steady state.
# FIELD_CRYPTO_KEY_PREVIOUS=

# AUDIT_EXPORT_SIGN_KEY must carry an explicit scheme prefix:
#   - "base64:<44-char seed>"        — strict 32-byte base64 (preferred)
#   - "passphrase:<>=16 char string>" — SHA-256 hashed deterministic seed
AUDIT_EXPORT_SIGN_KEY=passphrase:<fill-with-at-least-16-chars>

# ── Redis (mandatory in production) ───────────────────────────────────────
# Smoke runs in NODE_ENV=production so env.ts:superRefine rejects boot
# without REDIS_URL. Point at an Upstash test database or a local
# Redis instance.
REDIS_URL=https://example-test.upstash.io
REDIS_TOKEN=<fill-with-upstash-token>

# ── Application ───────────────────────────────────────────────────────────
APP_ORIGIN=http://127.0.0.1:3500
LOG_LEVEL=info
# Default OFF. Only flip to "true" temporarily to test a stale v1-auth
# client path.
ALLOW_LEGACY_AUTH=false

# ── Optional ──────────────────────────────────────────────────────────────
# FALLBACK_RPC_URL=
# COINGECKO_API_KEY=
# SENTRY_DSN=https://...@o000000.ingest.sentry.io/0000000
# SENTRY_TRACES_SAMPLE_RATE=0.1
