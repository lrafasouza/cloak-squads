generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model AuditLink {
  id           String   @id @default(uuid())
  cofreAddress String
  diversifier  Bytes
  scope        String
  scopeParams  String?
  expiresAt    DateTime
  issuedBy     String
  signature    Bytes
  createdAt    DateTime @default(now())

  @@index([cofreAddress])
}

model StealthInvoice {
  id                  String   @id @default(uuid())
  cofreAddress        String
  invoiceRef          String?
  memo                String?
  stealthPubkey       String
  amountHintEncrypted Bytes?
  status              String
  expiresAt           DateTime
  createdAt           DateTime @default(now())

  @@index([cofreAddress])
  @@index([stealthPubkey])
}

model ProposalDraft {
  id               String   @id @default(uuid())
  cofreAddress     String
  transactionIndex String
  amount           String
  recipient        String
  memo             String?
  payloadHash      Bytes
  invariants       String
  commitmentClaim  String?
  signature        String?
  createdAt        DateTime @default(now())

  @@unique([cofreAddress, transactionIndex])
  @@index([cofreAddress])
}

model PayrollDraft {
  id               String   @id @default(uuid())
  cofreAddress     String
  transactionIndex String
  memo             String?
  totalAmount      String
  recipientCount   Int
  createdAt        DateTime @default(now())

  recipients PayrollRecipient[]

  @@unique([cofreAddress, transactionIndex])
  @@index([cofreAddress])
}

model PayrollRecipient {
  id              String @id @default(uuid())
  payrollDraftId  String
  name            String
  wallet          String
  amount          String
  memo            String?
  payloadHash     Bytes
  invariants      String
  commitmentClaim String?
  signature       String?
  createdAt       DateTime @default(now())

  payrollDraft PayrollDraft @relation(fields: [payrollDraftId], references: [id], onDelete: Cascade)

  @@index([payrollDraftId])
}
