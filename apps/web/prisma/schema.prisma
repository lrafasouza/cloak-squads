generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AuditLink {
  id           String   @id @default(uuid())
  cofreAddress String
  diversifier  Bytes
  scope        String
  scopeParams  String?
  expiresAt    DateTime
  issuedBy     String
  signature    Bytes
  createdAt    DateTime @default(now())

  @@index([cofreAddress])
}

model Vault {
  id                String   @id @default(uuid())
  cofreAddress      String   @unique
  name              String
  description       String?
  avatarUrl         String?
  createdBy         String?
  emailNotifications Boolean @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  settings VaultSettings?

  @@index([cofreAddress])
}

model VaultSettings {
  id           String  @id @default(uuid())
  cofreAddress String  @unique
  webhookUrl   String?
  rpcOverride  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  vault Vault @relation(fields: [cofreAddress], references: [cofreAddress], onDelete: Cascade)

  @@index([cofreAddress])
}

model SubVault {
  id           String   @id @default(uuid())
  cofreAddress String
  vaultIndex   Int
  name         String
  color        String?
  icon         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([cofreAddress, vaultIndex])
  @@index([cofreAddress])
}

model StealthInvoice {
  id                  String   @id @default(uuid())
  cofreAddress        String
  recipientWallet     String
  invoiceRef          String?
  memo                String?
  stealthPubkey       String
  signPubkey          String?
  amountHint          Bytes?
  status              String
  expiresAt           DateTime
  createdAt           DateTime @default(now())
  claimedAt           DateTime?
  claimedBy           String?
  vaultIndex          Int      @default(0)

  // Cloak UTXO data for claim
  utxoAmount          String?
  utxoPrivateKey      String?
  utxoPublicKey       String?
  utxoBlinding        String?
  utxoMint            String?
  utxoLeafIndex       Int?
  utxoCommitment      String?
  utxoSiblingCommitment String?
  utxoLeftSiblingCommitment String?

  @@index([cofreAddress])
  @@index([stealthPubkey])
}

model ProposalDraft {
  id               String   @id @default(uuid())
  cofreAddress     String
  transactionIndex String
  amount           String
  recipient        String
  memo             String?
  payloadHash      Bytes
  invariants       String
  commitmentClaim  String?
  signature        String?
  vaultIndex       Int      @default(0)
  createdAt        DateTime @default(now())
  archivedAt      DateTime?

  @@unique([cofreAddress, transactionIndex])
  @@index([cofreAddress])
  @@index([cofreAddress, archivedAt])
}

model PayrollDraft {
  id               String   @id @default(uuid())
  cofreAddress     String
  transactionIndex String
  memo             String?
  totalAmount      String
  recipientCount   Int
  mode             String   @default("direct")
  vaultIndex       Int      @default(0)
  createdAt        DateTime @default(now())

  recipients PayrollRecipient[]

  @@unique([cofreAddress, transactionIndex])
  @@index([cofreAddress])
}

model SwapDraft {
  id               String   @id @default(uuid())
  cofreAddress     String
  transactionIndex String
  inputMint        String
  outputMint       String
  inputAmount      String
  outputAmount     String
  inputSymbol      String
  outputSymbol     String
  memo             String?
  vaultIndex       Int      @default(0)
  createdAt        DateTime @default(now())

  @@unique([cofreAddress, transactionIndex])
  @@index([cofreAddress])
}

model AddressBookEntry {
  id          String   @id @default(uuid())
  ownerPubkey String
  label       String
  address     String
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([ownerPubkey, address])
  @@index([ownerPubkey])
}

model PayrollRecipient {
  id              String  @id @default(uuid())
  payrollDraftId  String
  name            String
  wallet          String
  amount          String
  memo            String?
  payloadHash     Bytes
  invariants      String
  commitmentClaim String?
  invoiceId       String?
  signature       String?
  createdAt       DateTime @default(now())

  payrollDraft PayrollDraft @relation(fields: [payrollDraftId], references: [id], onDelete: Cascade)

  @@index([payrollDraftId])
}
