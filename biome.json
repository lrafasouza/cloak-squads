{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "files": {
    "ignore": [
      "**/target/**",
      "target/**",
      "node_modules/**",
      ".turbo/**",
      ".anchor/**",
      "**/.next/**",
      "**/dist/**",
      "**/coverage/**",
      "pnpm-lock.yaml",
      "**/*.tsbuildinfo"
    ]
  },
  "organizeImports": { "enabled": true },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": {
        "noNonNullAssertion": "off",
        "useNodejsImportProtocol": "off"
      },
      "performance": {
        "noDelete": "off"
      },
      "suspicious": {
        "noArrayIndexKey": "off"
      },
      "correctness": {
        "useExhaustiveDependencies": "warn"
      }
    }
  },
  "overrides": [
    {
      "include": ["apps/web/app/api/circuits/**", "apps/web/app/api/cloak-relay/**"],
      "linter": {
        "rules": {
          "suspicious": {
            "noControlCharactersInRegex": "off"
          }
        }
      }
    },
    {
      "include": [
        "apps/web/components/ui/**",
        "apps/web/components/vault/SendModal.tsx",
        "apps/web/components/vault/SwapModal.tsx",
        "apps/web/components/wallet/WalletMenu.tsx",
        "apps/web/app/vault/[multisig]/swap/page.tsx"
      ],
      "linter": {
        "rules": {
          "a11y": {
            "useSemanticElements": "off"
          }
        }
      }
    }
  ],
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  }
}
