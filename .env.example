# ════════════════════════════════════════════════════════════════════════════
#  Aegis — Environment Variables
#  All NEXT_PUBLIC_* vars are baked at build time. Server-only vars are
#  injected at runtime.
# ════════════════════════════════════════════════════════════════════════════

# ── Solana ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SOLANA_CLUSTER=devnet
NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com
#   ^ For production with many users, switch to a dedicated RPC (Helius/QuickNode)

# ── Cloak (privacy layer) ───────────────────────────────────────────────────
NEXT_PUBLIC_CLOAK_PROGRAM_ID=Zc1kHfp4rajSMeASFDwFFgkHRjv7dFQuLheJoQus27h
NEXT_PUBLIC_CLOAK_RELAY_URL=https://api.devnet.cloak.ag

NEXT_PUBLIC_GATEKEEPER_PROGRAM_ID=AgFx8yS8bQnXSCSGfN3f8oz3HJGeF5rwLoWtfHTEEaAq
NEXT_PUBLIC_SQUADS_PROGRAM_ID=SQDS4ep65T869zMMBKyuUq6aD6EgTu8psMjkvj52pCf

# ── Database ──────────────────────────────────────────────────────────────
#   Local dev (use docker compose up -d postgres):
#     DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aegis_dev
#   Production (Render, Supabase, etc.):
#     DATABASE_URL=postgresql://user:pass@host:5432/db
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aegis_dev

# ── Secrets ───────────────────────────────────────────────────────────────
#   Generate strong secrets (min 16 chars each):
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
#   The three vars below are MANDATORY in production (env.ts superRefine
#   fails the boot if any is missing). They're purpose-specific so a leak
#   in one subsystem (sessions / challenges / encrypted PII / audit
#   signatures) does not compromise the others.
#
#   JWT_SIGNING_SECRET is DEPRECATED — kept only so existing .env files
#   pass the schema parse during the cutover. The runtime crypto helpers
#   no longer read it. Remove once you've confirmed the three keys below
#   are set.
# JWT_SIGNING_SECRET=
#   HMAC key for stateless tokens (session cookies + claim challenges).
#   Each call site domain-separates further (session-hmac-v1:, challenge-hmac-v1:)
#   so the two derived keys are cryptographically distinct.
SESSION_HMAC_KEY=
#   AES-256-GCM key for field-crypto (stealth memos, UTXO secrets, operator
#   deposit cache). Rotation requires the rotate-field-crypto script + the
#   FIELD_CRYPTO_KEY_PREVIOUS env temporarily set.
FIELD_CRYPTO_KEY=
#   Optional dual-read fallback during a FIELD_CRYPTO_KEY rotation. Leave
#   empty under steady state. Set during rotation, remove after the
#   rotate-field-crypto script completes.
# FIELD_CRYPTO_KEY_PREVIOUS=
#   Ed25519 signing seed for audit-export signatures. Either base64 of 32
#   bytes (preferred) or any string (audit-sign.ts derives the seed via SHA-256).
#   Rotating only impacts NEW exports — historical exports embed their
#   own verifying pubkey and remain offline-verifiable.
AUDIT_EXPORT_SIGN_KEY=

# ── Logging ───────────────────────────────────────────────────────────────
LOG_LEVEL=debug

# ── Redis (optional — for distributed rate limiting and one-time challenges) ─
#   Leave empty to use in-memory rate limiting (single-instance only).
#   For production multi-instance, use Upstash Redis or similar.
# REDIS_URL=https://your-redis.upstash.io
# REDIS_TOKEN=your-upstash-token

# ── Wallet auth signature format (S6) ─────────────────────────────────────
#   "true"  = accept both v1 (legacy) and v2 (endpoint-bound) signatures.
#   "false" = enforce v2 only. Flip to "false" after 7 days in production.
ALLOW_LEGACY_AUTH=true
